---
const footerLinks = [
  { label: 'Home', href: '/' },
  { label: 'What We Do', href: '/what-we-do' },
  { label: 'Projects', href: '/projects' },
  { label: 'Research', href: '/research' },
  { label: 'Team', href: '/team' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="footer">
  <div class="footer-inner wrap">
    <div class="footer-grid">
      <div class="footer-info">
        <p class="footer-address">
          135 West 41st Street, 5th Floor<br />
          New York NY 10036<br /><br />
          Av. Apoquindo 5950,<br />
          Las Condes, Santiago, Chile
        </p>
      </div>

      <div class="footer-nav">
        {footerLinks.map(link => (
          <a href={link.href} class="footer-link">
            {link.label}
            <img src="/icons/arrow-outward-white.svg" alt="" width="14" class="footer-link-arrow" />
          </a>
        ))}
      </div>

      <div class="footer-social">
        <a href="https://twitter.com/ConsiliumBots" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
          <img src="/icons/x-twitter.svg" alt="X" width="20" />
        </a>
        <a href="https://www.linkedin.com/company/consiliumbots/about/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <img src="/icons/linkedin.svg" alt="LinkedIn" width="20" />
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-mission">
        ConsiliumBots is a nonprofit organization with the mission of fostering technological innovation to connect government data with the community.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary-dark);
    color: var(--color-white);
    padding: 64px 0 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr auto;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-address {
    font-size: 0.875rem;
    line-height: 1.7;
    opacity: 0.85;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    color: var(--color-white);
    opacity: 0.85;
    transition: opacity 0.2s ease;
    padding: 4px 0;
  }

  .footer-link:hover {
    opacity: 1;
  }

  .footer-link-arrow {
    opacity: 0.6;
  }

  .footer-social {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .footer-social a {
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer-social a:hover {
    opacity: 1;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 24px;
  }

  .footer-mission {
    font-size: 0.85rem;
    opacity: 0.7;
    max-width: 700px;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
