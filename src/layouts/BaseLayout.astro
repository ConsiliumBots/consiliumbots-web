---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
// Self-hosted fonts (latin subset covers English + Spanish) — no third-party request
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';
import '@fontsource/baskervville/latin-400.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Using technology to help families make important decisions in education and other social impact areas. Working with governments to reach out to their users.',
  ogImage = '/images/og-image.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://www.consiliumbots.com';

// Organization + WebSite structured data (Schema.org) for entity recognition
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'ConsiliumBots',
      url: `${siteUrl}/`,
      logo: `${siteUrl}/images/consiliumbots-logo.svg`,
      description:
        'A technology nonprofit using data and AI to help people make better decisions about education, housing, and government benefits across Latin America and the U.S.',
      sameAs: [
        'https://twitter.com/ConsiliumBots',
        'https://www.linkedin.com/company/consiliumbots/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'ConsiliumBots',
      url: `${siteUrl}/`,
      publisher: { '@id': `${siteUrl}/#organization` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ConsiliumBots" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ConsiliumBots" />
    <meta name="twitter:creator" content="@ConsiliumBots" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Fonts are self-hosted via @fontsource (imported in the layout frontmatter) -->

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <!-- Structured data (Schema.org) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
