---
import BaseLayout from '../../layouts/BaseLayout.astro';

// NOTE: no public contact email is published yet — confirm which address to surface
// (e.g. info@consiliumbots.com) and it can be wired as a mailto button here.
const offices = [
  { city: 'New York', lines: ['135 West 41st Street, 5th Floor', 'New York, NY 10036', 'United States'] },
  { city: 'Santiago', lines: ['Av. Apoquindo 5950', 'Las Condes', 'Santiago, Chile'] },
];

const socials = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/consiliumbots/about/', icon: '/icons/linkedin.svg' },
  { label: 'X (Twitter)', href: 'https://twitter.com/ConsiliumBots', icon: '/icons/x-twitter.svg' },
];
---

<BaseLayout
  lang="es"
  title="Contacto | ConsiliumBots"
  description="Contáctate con ConsiliumBots — una organización sin fines de lucro que usa datos y tecnología para ayudar a las personas a tomar decisiones importantes."
>
  <section class="page-hero">
    <div class="wrap">
      <h1>Contacto</h1>
      <p>
        Si tienes una idea o quieres formar parte del equipo de ConsiliumBots, nos encantaría saber de ti.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap contact-grid">
      <div>
        <h2 class="section-title">Oficinas</h2>
        <div class="offices">
          {offices.map((o) => (
            <div class="office">
              <h3>{o.city}</h3>
              <address>{o.lines.map((l) => <span>{l}</span>)}</address>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="section-title">Conéctate</h2>
        <div class="socials">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="social">
              <img src={s.icon} alt="" width="20" />
              {s.label}
            </a>
          ))}
        </div>
        <p class="join-note">
          Somos un equipo diverso e interdisciplinario con base en EE. UU., Chile y Colombia, y
          siempre nos interesa conectar con investigadores, aliados y colaboradores.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .offices {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .office h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .office address {
    font-style: normal;
    color: var(--color-text-light);
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .office address span {
    display: block;
  }
  .socials {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  .social {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .join-note {
    font-size: 0.92rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 460px;
  }
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
